{
  "name": "my-needle-engine-project",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite --host",
    "start": "npm run dev",
    "build": "vite build -- --production",
    "build:production": "npm run build",
    "build:dev": "vite build",
    "deploy": "npm run build && npx --yes needle-cloud deploy build --token",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "@needle-tools/engine": "^4.16.0",
    "three": "npm:@needle-tools/three@^0.169.19"
  },
  "devDependencies": {
    "@needle-tools/helper": "^1.11.5",
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/three": "0.169.0",
    "dotenv": "^16.4.7",
    "glob": "^11.0.0",
    "mdsvex": "^0.12.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.4",
    "vite": "^6.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-static-copy": "^2.0.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0"
  }
}
